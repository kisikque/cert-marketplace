generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROVIDER
  CUSTOMER
}

enum OrderStatus {
  NEW
  IN_REVIEW
  WAITING_DOCS
  APPROVED
  REJECTED
  DONE
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  displayName  String?
  isDeleted    Boolean  @default(false)

  providerProfile      ProviderProfile?
  orders               Order[]                        @relation("CustomerOrders")
  statusChanges        OrderStatusHistory[]           @relation("StatusChangedBy")
  uploadedDocs         OrderDocument[]                @relation("DocUploadedBy")
  uploadedProviderDocs ProviderVerificationDocument[] @relation("ProviderDocUploadedBy")
  serviceReviews       ServiceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderProfile {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id])

  orgName             String
  inn                 String?
  phone               String?
  address             String?
  website             String?
  description         String?
  logoUrl             String?
  publicSlug          String?            @unique
  verificationStatus  VerificationStatus @default(PENDING)
  verificationComment String?
  submittedAt         DateTime?
  verifiedAt          DateTime?
  ratingAvg           Float              @default(0)
  ratingCount         Int                @default(0)

  services              Service[]
  orders                Order[]
  verificationDocuments ProviderVerificationDocument[]
  serviceReviews        ServiceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderVerificationDocument {
  id                String @id @default(cuid())
  providerProfileId String
  uploadedByUserId  String

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  uploadedBy      User            @relation("ProviderDocUploadedBy", fields: [uploadedByUserId], references: [id])

  fileName     String
  mimeType     String
  size         Int
  storagePath  String
  documentType String?

  createdAt DateTime @default(now())

  @@index([providerProfileId])
  @@index([uploadedByUserId])
}

model Service {
  id         String @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id])

  internalCode String
  title        String
  description  String
  priceFrom    Int?
  etaDaysFrom  Int?
  imageUrl     String?
  isActive     Boolean @default(true)
  ratingAvg    Float   @default(0)
  ratingCount  Int     @default(0)

  orderItems OrderItem[]
  tags       ServiceTag[]
  reviews    ServiceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@unique([providerId, internalCode])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  services ServiceTag[]
}

model ServiceTag {
  serviceId String
  tagId     String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serviceId, tagId])
  @@index([tagId])
}

model Order {
  id         String @id @default(cuid())
  customerId String
  providerId String

  customer User            @relation("CustomerOrders", fields: [customerId], references: [id])
  provider ProviderProfile @relation(fields: [providerId], references: [id])

  status          OrderStatus @default(NEW)
  customerComment String?
  providerComment String?

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  documents     OrderDocument[]
  reviews       ServiceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([providerId])
  @@index([status])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  serviceId String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  qty             Int @default(1)
  priceAtPurchase Int?
  review          ServiceReview?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([serviceId])
}

model ServiceReview {
  id             String @id @default(cuid())
  serviceId      String
  providerId     String
  customerId     String
  orderId        String
  orderItemId    String @unique
  rating         Int
  text           String?
  isAnonymous    Boolean @default(true)
  displayUserId  Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  service   Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  provider  ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  customer  User            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([providerId])
  @@index([customerId])
  @@index([orderId])
}

model OrderStatusHistory {
  id              String @id @default(cuid())
  orderId         String
  changedByUserId String

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User  @relation("StatusChangedBy", fields: [changedByUserId], references: [id])

  fromStatus OrderStatus?
  toStatus   OrderStatus
  comment    String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([changedByUserId])
}

model OrderDocument {
  id               String @id @default(cuid())
  orderId          String
  uploadedByUserId String

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation("DocUploadedBy", fields: [uploadedByUserId], references: [id])

  fileName    String
  mimeType    String
  size        Int
  storagePath String

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([uploadedByUserId])
}
